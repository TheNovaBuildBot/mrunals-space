description: "Mrunal Parikh — Experienced SDET and Test Operations Leader with 15+ years at Meta and across the tech industry. Based in California."
---

{% include "header.njk" %}

<!-- Hero -->
<section class="hero">
  <div class="wrap">
    <div class="hero-inner">
      <img src="/assets/use-this-as-my-profile-picture.jpg" alt="{{ site.name }}" class="profile-photo">
      <div class="hero-label">SDET &amp; Test Operations Leader</div>
      <h1>{{ site.name }}</h1>
      <p class="subtitle">{{ site.specialty }}</p>
      <p class="tagline">"{{ site.tagline }}"</p>
      <div class="hero-cta">
        <a href="#contact" class="btn btn-accent">Get In Touch</a>
        <a href="{{ site.linkedin }}" target="_blank" class="btn btn-outline-light">View LinkedIn</a>
      </div>
    </div>
  </div>
</section>

<!-- About -->
<section id="about" class="about">
  <div class="wrap">
    <div class="about-grid">
      <div class="about-sidebar">
        <div class="stat">
          <div class="num">15+</div>
          <div class="lbl">Years in Tech</div>
        </div>
        <div class="stat">
          <div class="num">Meta</div>
          <div class="lbl">Current Company</div>
        </div>
        <div class="stat">
          <div class="num">500+</div>
          <div class="lbl">LinkedIn Connections</div>
        </div>
      </div>
      <div>
        <div class="section-label">About Me</div>
        <h2 class="section-title">Professional Background</h2>
        <div class="section-divider"></div>
        <div class="about-text">
          <p>With over 15 years of experience in the software testing industry, I specialize in leading test operations across various platforms and technologies. Currently at <strong>Meta</strong>, I bring deep expertise in SDET practices, test automation, and quality assurance leadership.</p>
          <p>My career has been defined by building robust test infrastructure, implementing comprehensive automation frameworks, and leading high-performing QA teams to deliver exceptional software quality at scale.</p>
          <p>I hold a graduate degree from <strong>The University of Texas at Dallas</strong> (2006–2008), where I developed a strong foundation in technical skills that have evolved throughout my career.</p>
        </div>
        <div class="skill-tags">
          <span class="skill-tag">Test Automation</span>
          <span class="skill-tag">SDET</span>
          <span class="skill-tag">Test Operations</span>
          <span class="skill-tag">CI/CD</span>
          <span class="skill-tag">Quality Engineering</span>
          <span class="skill-tag">Team Leadership</span>
          <span class="skill-tag">Infrastructure</span>
          <span class="skill-tag">Scalable Testing</span>
        </div>
        <a href="{{ site.linkedin }}" target="_blank" class="btn btn-primary">View Full Profile on LinkedIn</a>
      </div>
    </div>
  </div>
</section>

<!-- Experience -->
<section id="experience" class="experience">
  <div class="wrap">
    <div style="text-align: center; margin-bottom: 56px;">
      <div class="section-label">Career</div>
      <h2 class="section-title">Experience &amp; Education</h2>
      <div class="section-divider" style="margin: 0 auto 24px;"></div>
    </div>
    <div class="exp-grid">
      <div class="exp-card">
        <div class="period">Current Role</div>
        <h3>SDET / Test Operations Leader</h3>
        <div class="company">Meta</div>
        <p>Leading test operations and automation initiatives for large-scale platforms. Driving quality excellence through innovative testing strategies, building scalable test infrastructure, and mentoring engineering teams.</p>
      </div>
      <div class="exp-card">
        <div class="period">Education • 2006–2008</div>
        <h3>Graduate Studies</h3>
        <div class="company">The University of Texas at Dallas</div>
        <p>Advanced studies in computer science and software engineering. Developed strong foundations in algorithms, system design, and software quality principles that have shaped my career in test engineering.</p>
      </div>
      <div class="exp-card">
        <div class="period">Expertise</div>
        <h3>Test Infrastructure &amp; Automation</h3>
        <div class="company">15+ Years Across Industry</div>
        <p>Extensive experience building and scaling test automation frameworks, CI/CD pipelines, and quality processes. Proven track record of transforming QA organizations and improving release velocity.</p>
      </div>
      <div class="exp-card">
        <div class="period">Leadership</div>
        <h3>QA Team Building</h3>
        <div class="company">Cross-Functional Impact</div>
        <p>Built and led high-performing QA and SDET teams. Established testing best practices, mentorship programs, and quality culture across organizations of varying scale and complexity.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-banner">
  <div class="wrap">
    <h2>Let's Connect</h2>
    <p>Interested in collaboration, mentorship, or discussing test engineering? I'd love to hear from you.</p>
    <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;">
      <a href="mailto:{{ site.email }}" class="btn btn-accent">Send Email</a>
      <a href="{{ site.linkedin }}" target="_blank" class="btn btn-outline-light">Connect on LinkedIn</a>
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" class="contact">
  <div class="wrap">
    <div class="contact-center">
      <div class="section-label">Contact</div>
      <h2 class="section-title">Get In Touch</h2>
      <div class="section-divider" style="margin: 0 auto 24px;"></div>
      <p style="color: var(--text-light); margin-bottom: 8px;">Based in {{ site.city }}. Available for professional opportunities, collaborations, and mentorship.</p>
      <div class="contact-links">
        <a href="mailto:{{ site.email }}" class="contact-card">
          <div class="icon">✉</div>
          <div>
            <div class="label">Email</div>
            <div class="val">{{ site.email }}</div>
          </div>
        </a>
        <a href="tel:{{ site.phone }}" class="contact-card">
          <div class="icon">📞</div>
          <div>
            <div class="label">Phone</div>
            <div class="val">{{ site.phone_display }}</div>
          </div>
        </a>
        <a href="{{ site.linkedin }}" target="_blank" class="contact-card">
          <div class="icon">💼</div>
          <div>
            <div class="label">LinkedIn</div>
            <div class="val">View Profile</div>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

{% include "footer.njk" %}
