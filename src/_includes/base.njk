<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title or site.title_suffix }}</title>
<meta name="description" content="{{ description or '' }}">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ title or site.title_suffix }}">
<meta property="og:description" content="{{ description or '' }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:image" content="{{ site.url }}/assets/use-this-as-my-profile-picture.jpg">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title or site.title_suffix }}">
<meta name="twitter:description" content="{{ description or '' }}">
<meta name="twitter:image" content="{{ site.url }}/assets/use-this-as-my-profile-picture.jpg">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"Person","name":"{{ site.name }}","jobTitle":"{{ site.specialty }}","url":"{{ site.url }}","email":"{{ site.email }}","telephone":"{{ site.phone_display }}","address":{"@type":"PostalAddress","addressLocality":"San Francisco Bay Area","addressRegion":"California","addressCountry":"US"},"sameAs":["{{ site.linkedin }}"],"description":"{{ site.tagline }}"}
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% if site.ga_id %}
<script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga_id }}"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','{{ site.ga_id }}');</script>
{% endif %}
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --primary: #1A1A2E;
  --primary-light: #EDEEF5;
  --primary-mid: #16213E;
  --accent: #D4A574;
  --accent-light: #FDF6EF;
  --accent-dark: #B8895C;
  --navy: #0F0F23;
  --text: #2C2C3E;
  --text-light: #6B6B80;
  --text-muted: #9E9EB0;
  --bg: #FFFFFF;
  --bg-warm: #FAFAFA;
  --bg-off: #F5F5F8;
  --border: #E8E8F0;
  --white: #FFFFFF;
  --serif: 'Playfair Display', Georgia, serif;
  --sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 20px rgba(0,0,0,0.06);
  --shadow-lg: 0 12px 40px rgba(0,0,0,0.1);
  --radius: 12px;
}
html { scroll-behavior: smooth; }
body { font-family: var(--sans); color: var(--text); background: var(--bg); font-size: 15px; line-height: 1.75; -webkit-font-smoothing: antialiased; }
img { max-width: 100%; display: block; }
a { text-decoration: none; color: inherit; }

.wrap { max-width: 1100px; margin: 0 auto; padding: 0 28px; }
.btn {
  display: inline-block; padding: 13px 30px; border-radius: 8px;
  font-family: var(--sans); font-size: 14px; font-weight: 600;
  letter-spacing: 0.01em; cursor: pointer; border: 2px solid transparent;
  transition: all 0.3s ease;
}
.btn-accent { background: var(--accent); color: var(--white); border-color: var(--accent); }
.btn-accent:hover { background: var(--accent-dark); border-color: var(--accent-dark); transform: translateY(-1px); box-shadow: var(--shadow-md); }
.btn-outline-light { background: transparent; color: var(--white); border-color: rgba(255,255,255,0.3); }
.btn-outline-light:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.6); }
.btn-primary { background: var(--primary); color: var(--white); border-color: var(--primary); }
.btn-primary:hover { background: var(--primary-mid); transform: translateY(-1px); box-shadow: var(--shadow-md); }
.btn-outline { background: transparent; color: var(--primary); border-color: var(--border); }
.btn-outline:hover { background: var(--primary-light); border-color: var(--primary); }
.section-label {
  font-size: 12px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--accent); margin-bottom: 10px;
}
.section-title {
  font-family: var(--serif); font-size: clamp(28px, 3.8vw, 40px);
  font-weight: 700; line-height: 1.2; margin-bottom: 16px; color: var(--navy);
}
.section-divider {
  width: 44px; height: 3px; background: var(--accent);
  border-radius: 2px; margin-bottom: 24px;
}

/* ── Header ─── */
header {
  background: var(--white); position: sticky; top: 0; z-index: 100;
  border-bottom: 1px solid var(--border); box-shadow: var(--shadow-sm);
}
.header-inner {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 0; gap: 24px;
}
.logo { flex-shrink: 0; }
.logo-name { font-family: var(--serif); font-size: 20px; font-weight: 700; color: var(--navy); }
nav { display: flex; gap: 28px; align-items: center; margin-left: auto; margin-right: 28px; }
nav a {
  font-size: 14px; font-weight: 500; color: var(--text-light);
  padding: 6px 0; position: relative; transition: color 0.3s;
}
nav a:hover { color: var(--primary); }

/* ── Hero ─── */
.hero {
  background: linear-gradient(135deg, var(--navy) 0%, #16213E 50%, #1A1A2E 100%);
  color: var(--white); min-height: 600px; display: flex; align-items: center;
  position: relative; overflow: hidden;
}
.hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 30% 50%, rgba(212,165,116,0.06) 0%, transparent 70%);
}
.hero-inner {
  display: flex; flex-direction: column; align-items: center; text-align: center;
  padding: 80px 0; position: relative; z-index: 1;
}
.profile-photo {
  width: 160px; height: 160px; border-radius: 50%; object-fit: cover;
  border: 4px solid rgba(212,165,116,0.3); box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  margin-bottom: 32px;
}
.hero-label {
  display: inline-block; font-size: 11px; font-weight: 600;
  letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent);
  background: rgba(212,165,116,0.1); border: 1px solid rgba(212,165,116,0.2);
  padding: 6px 16px; border-radius: 6px; margin-bottom: 20px;
}
.hero h1 { font-family: var(--serif); font-size: clamp(36px, 5vw, 54px); font-weight: 700; line-height: 1.1; margin-bottom: 12px; }
.hero .subtitle { font-size: 18px; color: rgba(255,255,255,0.5); margin-bottom: 8px; font-weight: 500; }
.hero .tagline { font-family: var(--serif); font-size: 17px; font-style: italic; color: rgba(212,165,116,0.8); margin-bottom: 36px; }
.hero-cta { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }

/* ── About ─── */
.about { padding: 100px 0; }
.about-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 64px; align-items: start; }
.about-sidebar {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-mid) 100%);
  color: var(--white); padding: 40px 32px; border-radius: var(--radius);
  box-shadow: var(--shadow-lg);
}
.about-sidebar .stat { text-align: center; padding: 20px 0; }
.about-sidebar .stat + .stat { border-top: 1px solid rgba(255,255,255,0.08); }
.about-sidebar .stat .num { font-family: var(--serif); font-size: 36px; font-weight: 700; color: var(--accent); line-height: 1; }
.about-sidebar .stat .lbl { font-size: 12px; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 6px; }
.about-text p { color: var(--text-light); margin-bottom: 16px; }
.skill-tags { display: flex; flex-wrap: wrap; gap: 8px; margin: 24px 0 32px; }
.skill-tag {
  background: var(--primary-light); color: var(--primary); padding: 6px 14px;
  border-radius: 20px; font-size: 13px; font-weight: 500;
}

/* ── Experience ─── */
.experience { padding: 100px 0; background: var(--bg-off); }
.exp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.exp-card {
  background: var(--white); border: 1px solid var(--border); border-radius: var(--radius);
  padding: 36px 28px; transition: all 0.3s ease;
}
.exp-card:hover { box-shadow: var(--shadow-lg); border-color: transparent; transform: translateY(-3px); }
.exp-card .period { font-size: 12px; font-weight: 600; color: var(--accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
.exp-card h3 { font-family: var(--serif); font-size: 20px; font-weight: 600; color: var(--navy); margin-bottom: 6px; }
.exp-card .company { font-size: 15px; font-weight: 600; color: var(--primary); margin-bottom: 12px; }
.exp-card p { font-size: 14px; color: var(--text-light); line-height: 1.7; }

/* ── Contact ─── */
.contact { padding: 100px 0; }
.contact-center { max-width: 700px; margin: 0 auto; text-align: center; }
.contact-links { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; margin-top: 36px; }
.contact-card {
  background: var(--bg-off); border: 1px solid var(--border); border-radius: var(--radius);
  padding: 24px 32px; display: flex; align-items: center; gap: 14px;
  transition: all 0.3s ease; min-width: 220px;
}
.contact-card:hover { box-shadow: var(--shadow-md); border-color: var(--accent); transform: translateY(-2px); }
.contact-card .icon { font-size: 24px; flex-shrink: 0; }
.contact-card .label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-muted); font-weight: 600; }
.contact-card .val { font-size: 14px; font-weight: 500; color: var(--text); margin-top: 2px; }
.contact-card a { color: var(--text); }
.contact-card a:hover { color: var(--accent); }

/* ── CTA ─── */
.cta-banner {
  background: linear-gradient(135deg, var(--primary) 0%, var(--navy) 100%);
  color: var(--white); padding: 68px 28px; text-align: center;
}
.cta-banner h2 { font-family: var(--serif); font-size: clamp(24px, 3.2vw, 36px); font-weight: 700; margin-bottom: 12px; }
.cta-banner p { font-size: 16px; opacity: 0.6; margin-bottom: 28px; max-width: 520px; margin-left: auto; margin-right: auto; }

/* ── Footer ─── */
footer { background: var(--navy); color: rgba(255,255,255,0.5); font-size: 13px; padding: 32px 0; text-align: center; }
footer a { color: rgba(255,255,255,0.5); transition: color 0.3s; }
footer a:hover { color: var(--accent); }
footer .sep { margin: 0 12px; opacity: 0.3; }

/* ── Responsive ─── */
@media (max-width: 960px) {
  .about-grid { grid-template-columns: 1fr; }
  .about-sidebar { max-width: 400px; margin: 0 auto; }
  .exp-grid { grid-template-columns: 1fr; }
  nav { display: none; }
}
@media (max-width: 600px) {
  .contact-links { flex-direction: column; align-items: center; }
  .contact-card { width: 100%; justify-content: center; }
}
</style>
</head>
<body>
{{ content | safe }}
<script>
document.querySelectorAll('a[href^="#"]').forEach(function(a) {
  a.addEventListener('click', function(e) {
    e.preventDefault();
    var el = document.querySelector(this.getAttribute('href'));
    if (el) el.scrollIntoView({ behavior: 'smooth' });
  });
});
</script>
</body>
</html>
